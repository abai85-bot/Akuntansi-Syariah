rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(docData) { return docData.ownerId == request.auth.uid; }

    // Validation Blueprints
    function isValidAccount(data) {
      return data.keys().hasAll(['code', 'name', 'type', 'category', 'balance', 'ownerId'])
          && data.keys().size() == 6
          && data.code is string && data.code.size() > 0 && data.code.size() <= 64
          && data.name is string && data.name.size() > 0 && data.name.size() <= 256
          && data.type is string && data.type in ['Asset', 'Liability', 'Equity', 'Income', 'Expense']
          && data.category is string && data.category.size() <= 128
          && data.balance is number
          && data.ownerId == request.auth.uid;
    }

    function isValidJournalEntry(data) {
      return data.keys().hasAll(['date', 'description', 'reference', 'items', 'ownerId', 'createdAt'])
          && data.keys().size() == 6
          && data.date is string && data.date.size() <= 32
          && data.description is string && data.description.size() <= 1024
          && data.reference is string && data.reference.size() <= 256
          && data.items is list && data.items.size() > 0 && data.items.size() <= 100
          && data.ownerId == request.auth.uid
          && data.createdAt is timestamp;
    }

    // Path Routes
    match /accounts/{accountId} {
      allow get: if isVerified() && isValidId(accountId) && isOwner(existing());
      allow list: if isVerified() && isOwner(existing());
      
      allow create: if isVerified() 
                    && isValidId(accountId) 
                    && isValidAccount(incoming());
                    
      allow update: if isVerified() 
                    && isValidId(accountId) 
                    && isOwner(existing())
                    && isValidAccount(incoming())
                    && incoming().ownerId == existing().ownerId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['code', 'name', 'type', 'category', 'balance']);
                    
      allow delete: if isVerified() 
                    && isValidId(accountId) 
                    && isOwner(existing());
    }

    match /journals/{journalId} {
      allow get: if isVerified() && isValidId(journalId) && isOwner(existing());
      allow list: if isVerified() && isOwner(existing());
      
      allow create: if isVerified() 
                    && isValidId(journalId) 
                    && isValidJournalEntry(incoming())
                    && incoming().createdAt == request.time;
                    
      allow update: if isVerified() 
                    && isValidId(journalId) 
                    && isOwner(existing())
                    && isValidJournalEntry(incoming())
                    && incoming().ownerId == existing().ownerId
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'description', 'reference', 'items']);
                    
      allow delete: if isVerified() 
                    && isValidId(journalId) 
                    && isOwner(existing());
    }
  }
}
